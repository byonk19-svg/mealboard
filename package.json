{
  "name": "mealboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "e2e": "playwright test",
    "e2e:auth-boundary": "playwright test e2e/auth-boundary.smoke.spec.ts --project=chromium",
    "e2e:headed": "playwright test e2e/core-loop.smoke.spec.ts --project=chromium --headed",
    "e2e:install": "playwright install chromium",
    "e2e:grocery-mobile": "playwright test e2e/grocery-mobile.smoke.spec.ts --project=chromium",
    "e2e:seed-local-user": "node scripts/bootstrap-local-e2e-user.mjs",
    "e2e:smoke": "playwright test e2e/core-loop.smoke.spec.ts --project=chromium",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
